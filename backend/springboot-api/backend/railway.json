{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend/springboot-api/backend && ./mvnw clean package -DskipTests"
  },
  "deploy": {
    "startCommand": "cd backend/springboot-api/backend && java -jar target/*.jar",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}